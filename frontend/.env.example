# Copier selon l'environnement :
#   cp .env.example .env.development   # dev local (npm run dev)
#   cp .env.example .env.production    # build VPS (npm run build)
#
# VITE_* est injecté au build par Vite (préfixe obligatoire).

# URL de base de l'API (sans /api à la fin).
# Laisser VIDE si le site et l'API sont sur la même origine (recommandé avec Nginx).
#
# Production VPS (Nginx :8080 sert / et /api) :
#   VITE_API_BASE=
#
# Si l'API est sur un autre hôte (cas rare) :
#   VITE_API_BASE=http://13.140.137.171:8080
#
# Dev local (npm run dev + proxy Vite → Flask :5050) :
#   VITE_API_BASE=

VITE_API_BASE=
