# Copier vers .env.worker pour le worker scrape / cron warm
# cp .env.worker.example .env.worker

DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=brvm_agent
MYSQL_USER=root
MYSQL_PASSWORD=changez-moi

REDIS_URL=redis://127.0.0.1:6379/0

# Le worker peut appeler Sikafinance
ALLOW_LIVE_QUOTE_FETCH=true
SCRAPE_BALANCE_SHEETS=true
SCRAPE_INTERVAL_HOURS=2
SCRAPE_ON_STARTUP=true

# Après chaque scrape : vider Redis + rebuild compare / home / …
WARM_CACHE_AFTER_SCRAPE=true

# Pas de planificateur dans un one-shot cron (scrape_companies.py gère le cycle)
DISABLE_SCRAPE_SCHEDULER=true
