# Copier vers .env et adapter les mots de passe
# cp .env.example .env

# --- Base de données ---
DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=brvm_agent
MYSQL_USER=root
MYSQL_PASSWORD=changez-moi
MYSQL_ROOT_PASSWORD=changez-moi

# --- API Flask ---
SECRET_KEY=changez-moi-en-production
CORS_ORIGINS=*
FLASK_DEBUG=false
PORT=5050

# --- Redis : docker compose up -d redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- Cache API (secondes) ---
LISTED_COMPANIES_CACHE_TTL=300
PALMARES_CACHE_TTL=300
MARKET_SUMMARY_CACHE_TTL=120
COMPARE_CACHE_TTL_SECONDS=300
HOME_CACHE_TTL_SECONDS=120
ANALYSIS_CACHE_TTL_SECONDS=1800
CACHE_BUILD_LOCK_SECONDS=120

# --- API (python3 app.py / gunicorn) ---
DISABLE_SCRAPE_SCHEDULER=true
SCRAPE_ON_STARTUP=false
ALLOW_LIVE_QUOTE_FETCH=false

# --- Worker (scrape_companies.py / run_scrape_worker.py / warm_api_cache) ---
SCRAPE_INTERVAL_HOURS=2
SCRAPE_BALANCE_SHEETS=true
WARM_CACHE_AFTER_SCRAPE=true

COMPARE_FETCH_BALANCE_SHEETS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# --- Comptes & abonnements ---
TRIAL_DURATION_DAYS=5
REFERRAL_COMMISSION_RATE=0.20
PAYMENT_MOCK=true

# --- Palmarès (slide Top hausses / baisses) ---
PALMARES_INTERVAL_HOURS=4
PALMARES_ON_STARTUP=true
# DISABLE_PALMARES_SCHEDULER=true
# PALMARES_FETCH_LIMIT=30
