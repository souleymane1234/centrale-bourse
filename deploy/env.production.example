# Copier vers /var/www/centrale-bourse/.env sur le VPS
# cp deploy/env.production.example .env && nano .env

# --- MySQL (instance déjà sur le VPS, port 3306 en général) ---
DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=brvm_agent
MYSQL_USER=centrale_bourse
MYSQL_PASSWORD=CHANGEZ_MOI

# --- Redis (utiliser /1 ou /2 si /0 est pris par une autre app) ---
REDIS_URL=redis://127.0.0.1:6379/2

# --- Sécurité ---
SECRET_KEY=CHANGEZ_MOI_LONGUE_CLE_ALEATOIRE
CORS_ORIGINS=https://bourse.votredomaine.com
FLASK_DEBUG=false

# --- API locale (ne pas exposer sur Internet) ---
GUNICORN_BIND=127.0.0.1:5051
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# --- Prod : pas de scrape côté visiteur ---
DISABLE_SCRAPE_SCHEDULER=true
SCRAPE_ON_STARTUP=false
ALLOW_LIVE_QUOTE_FETCH=false
PALMARES_ON_STARTUP=true
PALMARES_INTERVAL_HOURS=4

# --- Cache ---
HOME_CACHE_TTL_SECONDS=120
LISTED_COMPANIES_CACHE_TTL=300
ANALYSIS_CACHE_TTL_SECONDS=1800

# --- Limites ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
PAYMENT_MOCK=true

TRIAL_DURATION_DAYS=5
REFERRAL_COMMISSION_RATE=0.20
MAX_WATCHLIST_ITEMS=50
MAX_PRICE_ALERTS=20
