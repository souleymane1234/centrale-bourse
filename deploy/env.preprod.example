# Pré-production Ubuntu — sans domaine
# cp deploy/env.preprod.example .env && nano .env
# Remplacer IP_DU_VPS par l'IP publique du VPS (ex. 203.0.113.50)

DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=brvm_agent
MYSQL_USER=centrale_bourse
MYSQL_PASSWORD=CHANGEZ_MOI

SECRET_KEY=CHANGEZ_MOI_GENERER_AVEC_python3_import_secrets
# Même origine que le navigateur (Nginx :8080)
CORS_ORIGINS=http://IP_DU_VPS:8080
FLASK_DEBUG=false

REDIS_URL=redis://127.0.0.1:6379/0

# API en local ; Nginx :8080 fait le lien public
GUNICORN_BIND=127.0.0.1:5051
GUNICORN_WORKERS=3
GUNICORN_THREADS=2

DISABLE_SCRAPE_SCHEDULER=true
SCRAPE_ON_STARTUP=false
ALLOW_LIVE_QUOTE_FETCH=false
PALMARES_ON_STARTUP=true

HOME_CACHE_TTL_SECONDS=120
LISTED_COMPANIES_CACHE_TTL=300
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
PAYMENTS_ENABLED=false
PAYMENT_MOCK=true
NEWS_USE_DATABASE=true

TRIAL_DURATION_DAYS=5
MAX_WATCHLIST_ITEMS=50
MAX_PRICE_ALERTS=20

# --- Option sans Nginx : décommenter et utiliser le port 5051 ---
# GUNICORN_BIND=0.0.0.0:5051
# CORS_ORIGINS=http://IP_DU_VPS:5051
