# Pré-production — accès par IP, port 8080 (ne conflict pas avec le :80 existant)
# /etc/nginx/sites-available/centrale-bourse-preprod

upstream centrale_bourse_api {
    server 127.0.0.1:5051;
    keepalive 8;
}

server {
    listen 8080;
    listen [::]:8080;
    server_name _;

    root /var/www/centrale-bourse/static/frontend;
    index index.html;

    client_max_body_size 4M;

    access_log /var/log/nginx/centrale-bourse-preprod.access.log;
    error_log  /var/log/nginx/centrale-bourse-preprod.error.log;

    location /api/ {
        proxy_pass http://centrale_bourse_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location /assets/ {
        try_files $uri =404;
        expires 1d;
    }

    location /logo.png {
        try_files $uri =404;
        expires 1d;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
