# /etc/nginx/sites-available/centrale-bourse
# Adapter : server_name, chemins SSL, root static

upstream centrale_bourse_api {
    server 127.0.0.1:5051;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name bourse.votredomaine.com;

    # Redirection HTTPS (après certbot, ou décommenter)
    # return 301 https://$host$request_uri;

    root /var/www/centrale-bourse/static/frontend;
    index index.html;

    client_max_body_size 4M;

    location /api/ {
        proxy_pass http://centrale_bourse_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location /assets/ {
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    location /logo.png {
        try_files $uri =404;
        expires 7d;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# Bloc HTTPS (certbot peut l'ajouter automatiquement)
# server {
#     listen 443 ssl http2;
#     listen [::]:443 ssl http2;
#     server_name bourse.votredomaine.com;
#     ssl_certificate     /etc/letsencrypt/live/bourse.votredomaine.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/bourse.votredomaine.com/privkey.pem;
#     ...
# }
