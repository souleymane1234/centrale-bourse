# Copier vers .env.api pour le processus API (Gunicorn / python app.py en prod)
# cp .env.api.example .env.api

DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=brvm_agent
MYSQL_USER=root
MYSQL_PASSWORD=changez-moi

SECRET_KEY=changez-moi-en-production
CORS_ORIGINS=https://votre-domaine.com
FLASK_DEBUG=false
PORT=5050

REDIS_URL=redis://127.0.0.1:6379/0

# API publique : pas de scrape dans ce processus
DISABLE_SCRAPE_SCHEDULER=true
SCRAPE_ON_STARTUP=false

# Les visiteurs lisent Redis / JSON, pas Sikafinance
ALLOW_LIVE_QUOTE_FETCH=false

# Palmarès (slide) : rafraîchi lun–ven toutes les 4 h dans ce processus
# ou via cron scripts/refresh_palmares.py + DISABLE_PALMARES_SCHEDULER=true
PALMARES_INTERVAL_HOURS=4
PALMARES_ON_STARTUP=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

COMPARE_FETCH_BALANCE_SHEETS=false
LISTED_COMPANIES_CACHE_TTL=300
COMPARE_CACHE_TTL_SECONDS=300
HOME_CACHE_TTL_SECONDS=120
